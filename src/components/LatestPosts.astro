---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { defaultLocale, type Locale } from '../i18n/locales';
import { localePath, useTranslations } from '../i18n/utils';

interface Props {
	locale: Locale;
	count?: number;
}

const { locale, count = 6 } = Astro.props;
const t = useTranslations(locale);

const posts = (await getCollection('blog', ({ data }) => data.lang === locale))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, count);

const articleHref = (postId: string): string =>
	locale === defaultLocale ? `/blog/${postId}/` : `/${locale}/blog/${postId}/`;
---

<section class="latest">
	<div class="latest-inner">
		<div class="latest-head">
			<h2>{t('home.latestArticles')}</h2>
			<a href={localePath(locale, '/blog')} class="view-all">{t('home.viewAll')}</a>
		</div>
		<ul class="grid">
			{
				posts.map((post) => (
					<li>
						<a href={articleHref(post.id)}>
							{post.data.heroImage && (
								typeof post.data.heroImage.src === 'string' && post.data.heroImage.src.endsWith('.svg')
									? <img width="720" height="360" src={post.data.heroImage.src} alt="" />
									: <Image width={720} height={360} src={post.data.heroImage} alt="" />
							)}
							<div class="card-body">
								<h3 class="title">{post.data.title}</h3>
								<p class="date">
									<FormattedDate date={post.data.pubDate} locale={locale} />
								</p>
							</div>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</section>

<style>
	.latest {
		background: rgb(var(--gray-light));
		padding: clamp(2.5em, 5vw, 4em) clamp(1em, 4vw, 2em);
	}
	.latest-inner {
		max-width: 1100px;
		margin: 0 auto;
	}
	.latest-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5em 1em;
		margin-bottom: 1.5em;
	}
	.latest-head h2 {
		margin: 0;
		font-size: clamp(1.4em, 3vw, 1.8em);
		color: rgb(var(--black));
	}
	.view-all {
		font-weight: 600;
		text-decoration: none;
		color: var(--accent);
		font-size: 0.95em;
	}
	.view-all:hover {
		text-decoration: underline;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5em;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.grid li {
		display: flex;
	}
	.grid a {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		background: white;
		border-radius: var(--radius);
		overflow: hidden;
		box-shadow: var(--box-shadow);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		width: 100%;
	}
	.grid a:hover {
		transform: translateY(-4px);
		box-shadow: var(--box-shadow-hover);
	}
	.grid img {
		width: 100%;
		aspect-ratio: 2 / 1;
		object-fit: cover;
	}
	.card-body {
		padding: 1.25em;
	}
	.title {
		margin: 0 0 0.5em;
		color: rgb(var(--black));
		line-height: 1.3;
		font-size: 1.05em;
	}
	.date {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.85em;
	}
	.grid a:hover .title {
		color: var(--accent);
	}
	@media (max-width: 640px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
