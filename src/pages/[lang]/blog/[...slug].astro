---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import type { Locale } from '../../../i18n/locales';
import { getNonDefaultLocales } from '../../../i18n/utils';
import { getEventData } from '../../../utils/eventSchema';

export async function getStaticPaths() {
	const paths = [];
	for (const lang of getNonDefaultLocales()) {
		const posts = await getCollection('blog', ({ data }) => data.lang === lang);
		for (const post of posts) {
			paths.push({
				params: { lang, slug: post.id },
				props: { post, locale: lang },
			});
		}
	}
	return paths;
}

const { post, locale } = Astro.props as { post: CollectionEntry<'blog'>; locale: Locale };
const { Content } = await render(post);
const heroImageUrl = post.data.heroImage
	? new URL(post.data.heroImage.src, Astro.site).toString()
	: undefined;
const eventData = getEventData(post.id, post.data.description, heroImageUrl);
---

<BlogPost
	{...post.data}
	locale={locale}
	showPartnerCard={post.id.startsWith('msfs-2024-development-update-') || post.id.startsWith('navigraph-') || post.id.startsWith('flightsimexpo-2026-saint-paul-')}
	partnerCardSeed={post.id}
	eventData={eventData}
>
	<Content />
</BlogPost>
